import uuid
from fastapi import APIRouter, UploadFile, File, HTTPException
from fastapi.responses import JSONResponse
from pydantic import BaseModel
from core.rag import process_pdfs_and_create_session, ask_question

router = APIRouter()


# ── Request / Response models ──────────────────────────────────────────────

class AskRequest(BaseModel):
    session_id: str
    question:   str

class AskResponse(BaseModel):
    answer:       str
    chat_history: list[dict]


# ── POST /api/chat/upload ──────────────────────────────────────────────────
# Accepts multiple PDF files, runs the RAG pipeline, returns a session_id
# Frontend sends: FormData with one or more PDF files

@router.post("/upload")
async def upload_pdfs(files: list[UploadFile] = File(...)):
    if not files:
        raise HTTPException(status_code=400, detail="No files uploaded")

    # Validate all files are PDFs
    for f in files:
        if not f.filename.endswith(".pdf"):
            raise HTTPException(status_code=400, detail=f"{f.filename} is not a PDF")

    # Read all file bytes
    pdf_bytes_list = [await f.read() for f in files]

    # Generate unique session id for this upload
    session_id = str(uuid.uuid4())

    try:
        process_pdfs_and_create_session(pdf_bytes_list, session_id)
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

    return {
        "session_id": session_id,
        "files_processed": [f.filename for f in files],
        "message": "PDFs processed successfully. Use session_id to ask questions."
    }


# ── POST /api/chat/ask ─────────────────────────────────────────────────────
# Accepts session_id + question, returns AI answer + chat history

@router.post("/ask", response_model=AskResponse)
async def ask(body: AskRequest):
    if not body.question.strip():
        raise HTTPException(status_code=400, detail="Question cannot be empty")
    try:
        result = ask_question(body.session_id, body.question)
        return result
    except FileNotFoundError:
        raise HTTPException(
            status_code=404,
            detail="Session not found. Please upload PDFs first."
        )
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))