import os
from pypdf import PdfReader
from langchain_text_splitters import CharacterTextSplitter
from langchain_huggingface import HuggingFaceEmbeddings
from langchain_community.vectorstores import FAISS
from langchain.memory import ConversationBufferMemory
from langchain.chains import ConversationalRetrievalChain
from langchain_groq import ChatGroq
from core.prompts import CUSTOM_PROMPT

VECTOR_STORE_PATH = os.getenv("VECTOR_STORE_PATH", "./vector_store")

# ── Shared embeddings model (loaded once, reused) ─────────────────────────
embeddings = HuggingFaceEmbeddings(
  #  model_name="BAAI/bge-small-en-v1.5"
     model_name="all-MiniLM-L6-v2"
)

# ── In-memory store: session_id → conversation chain ──────────────────────
# In production, replace with Redis for multi-server support
active_sessions: dict = {}


def extract_text_from_pdfs(pdf_bytes_list: list[bytes]) -> str:
    """Extract raw text from a list of PDF byte buffers."""
    text = ""
    for pdf_bytes in pdf_bytes_list:
        import io
        reader = PdfReader(io.BytesIO(pdf_bytes))
        for page in reader.pages:
            extracted = page.extract_text()
            if extracted:
                text += extracted
    return text


def split_into_chunks(text: str) -> list[str]:
    """Split text into overlapping chunks for better retrieval."""
    splitter = CharacterTextSplitter(
        separator="\n",
        chunk_size=1000,
        chunk_overlap=200,
        length_function=len
    )
    return splitter.split_text(text)


def build_vectorstore(chunks: list[str], session_id: str) -> FAISS:
    """Create FAISS vector store and persist it to disk."""
    vectorstore = FAISS.from_texts(
        texts=chunks,
        embedding=embeddings
    )
    # Save to disk so it survives server restarts
    save_path = f"{VECTOR_STORE_PATH}/{session_id}"
    os.makedirs(save_path, exist_ok=True)
    vectorstore.save_local(save_path)
    return vectorstore


def load_vectorstore(session_id: str) -> FAISS:
    """Load an existing FAISS vector store from disk."""
    save_path = f"{VECTOR_STORE_PATH}/{session_id}"
    return FAISS.load_local(
        save_path,
        embeddings,
        allow_dangerous_deserialization=True
    )


def create_conversation_chain(vectorstore: FAISS) -> ConversationalRetrievalChain:
    """Build the RAG conversation chain — same as your Streamlit get_conversation_chain()."""
    llm = ChatGroq(model_name="llama-3.1-8b-instant")
    memory = ConversationBufferMemory(
        memory_key="chat_history",
        return_messages=True
    )
    return ConversationalRetrievalChain.from_llm(
        llm=llm,
        retriever=vectorstore.as_retriever(),
        memory=memory,
        combine_docs_chain_kwargs={"prompt": CUSTOM_PROMPT}
    )


def get_or_create_chain(session_id: str) -> ConversationalRetrievalChain:
    """Return existing chain for a session, or load from disk."""
    if session_id not in active_sessions:
        vectorstore = load_vectorstore(session_id)
        active_sessions[session_id] = create_conversation_chain(vectorstore)
    return active_sessions[session_id]


def process_pdfs_and_create_session(
    pdf_bytes_list: list[bytes],
    session_id: str
) -> str:
    """
    Full pipeline: PDF bytes → text → chunks → vectors → session.
    Returns session_id to use for subsequent /ask calls.
    """
    text   = extract_text_from_pdfs(pdf_bytes_list)
    chunks = split_into_chunks(text)
    vectorstore = build_vectorstore(chunks, session_id)
    active_sessions[session_id] = create_conversation_chain(vectorstore)
    return session_id


def ask_question(session_id: str, question: str) -> dict:
    """Ask a question against the session's vector store."""
    chain    = get_or_create_chain(session_id)
    response = chain.invoke({"question": question})
    return {
        "answer":       response["answer"],
        "chat_history": [
            {"role": "user" if i % 2 == 0 else "bot", "content": m.content}
            for i, m in enumerate(response["chat_history"])
        ]
    }